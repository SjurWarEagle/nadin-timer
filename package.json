    "@angular/compiler-cli": "^17.2.2",
    "@types/chance": "1.1.6",
    "@types/jasmine": "~5.1.4",
    "@types/lodash": "4.14.202",
    "@types/node": "20.11.20",
    "@typescript-eslint/eslint-plugin": "7.0.2",
    "@typescript-eslint/parser": "7.0.2",
